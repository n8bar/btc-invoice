APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://cryptozing.app
APP_PUBLIC_URL=${APP_URL}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
SAIL_PHP_EXTENSIONS="bcmath,pcntl,pdo_mysql,redis,gmp"

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=
MYSQL_EXTRA_OPTIONS=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

#MAIL_MAILER=log
#MAIL_FROM_ADDRESS="hello@example.com"
#MAIL_FROM_NAME="${APP_NAME}"

MAIL_MAILER=mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
MAILGUN_WEBHOOK_SIGNING_KEY=
MAIL_FROM_ADDRESS=no-reply@cryptozing.app
MAIL_FROM_NAME="CryptoZing"
MAIL_OUTBOUND_ENABLED=false
MAIL_MANUAL_SEND_COOLDOWN_MINUTES=60
MAIL_ALERT_COOLDOWN_MINUTES=1440
MAIL_ALIAS_ENABLED=true
MAIL_ALIAS_DOMAIN=mailer.cryptozing.app
SUPPORT_AGENT_EMAILS=
SUPPORT_ACCESS_HOURS=72
SUPPORT_ACCESS_TERMS_VERSION=v1


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
FORWARD_DB_PORT=3307
